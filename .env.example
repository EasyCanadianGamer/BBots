DISCORD_TOKEN=
CLIENT_ID=
SESSION_SECRET=replace-this-with-a-long-random-string

# Optional — if set, the dashboard is locked to this guild.
# If omitted, the guild is auto-detected via Discord OAuth2 at login.
GUILD_ID=

# Optional — welcome channel for auto-join messages.
# Can also be set from the dashboard Settings page instead.
WELCOME_CHANNEL_ID=

# Discord OAuth2 (required for dashboard login)
# Get Client Secret from: Developer Portal → your app → OAuth2
# Add redirect URI in the portal: http://localhost:3000/auth/discord/callback
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Optional
DASHBOARD_PORT=3000

# Notifications — Twitch (optional, needed for Twitch feeds)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Notifications — YouTube (optional, needed for YouTube feeds)
YOUTUBE_API_KEY=

# AI Chat (optional — only needed if AI feature is enabled)
# Set the key for whichever provider you use; leave others blank.
XAI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
